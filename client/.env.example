# ============================================================================
# 企业知识库 RAG 问答系统 - 前端环境变量
# ============================================================================
# 复制此文件为 .env 并根据环境修改配置
# ============================================================================

# API 基础路径（通过 vite proxy 转发到后端）
VITE_API_BASE_URL=/api

# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=120000

# 应用标题
VITE_APP_TITLE=企业知识库 RAG 问答系统
