# ============================================================================
# 企业知识库 RAG 问答系统 - 环境变量配置
# ============================================================================
# 复制此文件为 .env 并根据环境修改配置
# cp .env.example .env
# ============================================================================

# ---------- 密钥配置 ----------
SECRET_KEY=enterprise-oa-secret-key-2024
JWT_SECRET_KEY=jwt-secret-key-enterprise-2024

# ---------- MySQL 数据库 ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-database-password
DB_NAME=dbenterprise

# ---------- Ollama 配置 ----------
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:3b
LLM_MODEL_COMPLEX=qwen3:8b
EMBEDDING_MODEL=qwen3-embedding:4b

# ---------- Redis 缓存 ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---------- 日志配置 ----------
LOG_LEVEL=INFO
LOG_DIR=./logs

# ---------- Sentry 错误监控（可选） ----------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- Flask 环境 ----------
FLASK_ENV=development
